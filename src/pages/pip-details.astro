---
import Layout from "../layouts/Layout.astro";
import ModalAddNew from "../components/ui/ModalAddNew.astro";

import { Naira, Pounds } from "../components/Symbols";
---

<Layout title="HRPayHub :: PIP Details">
  <!-- Main content starts here -->
  <main>
    <!-- First section of Back button and Breadcrumb -->
    <section class="p-4">
      <div class="screenFrame">
        <!-- Back Navigation button and BreadCrumbs -->
        <div class="d-flex gap-5">
          <a
            href="/performance-improvement-plans"
            title="Back to Dashboard"
            class="d-flex gap-2 align-items-center text-decoration-none text-primary-dark"
          >
            <img src="images/png/icons/angle-left.svg" alt="angle-left-back" />
            <span class="fs-16 fw-bold font-avenir-bold">Back</span>
          </a>

          <!-- Actual Breadcrumb here -->
          <div class="d-flex align-items-center gap-2">
            <a
              href="index.html"
              class="fs-14 text-decoration-none text-primary-dark">Dashboard</a
            >
            <img
              src="images/png/icons/angle-right.svg"
              alt="angle-right-back"
            />
            <a
              href="/performance-management"
              class="fs-14 text-decoration-none text-primary-dark"
              >Performance Management</a
            >
            <img
              src="images/png/icons/angle-right.svg"
              alt="angle-right-back"
            />
            <a
              href="/performance-improvement-plan"
              class="fs-14 text-decoration-none text-primary-dark"
              >Performance Improvement Plan</a
            >
            <img
              src="images/png/icons/angle-right.svg"
              alt="angle-right-back"
            />
            <span class="fs-16 fw-bold text-primary-blue">PIP Details</span>
          </div>
          <!-- Actual Breadcrumb here -->
        </div>
        <!-- Back Navigation button and BreadCrumbs -->
      </div>
    </section>
    <!-- First section of Back button and Breadcrumb -->

    <!-- First section of Back button and Breadcrumb -->
    <section class="px-4">
      <div class="screenFrame">
        <div class="rounded-4 shadow p-4 vstack gap-5 px-5">
          {/* Page Content Box */}
          <div class="p-lg-5 w-75 mx-auto">
            <div class="vstack px-5" style="gap: 2.3rem">
              <div class="d-flex justify-content-between gap-3">
                <!---- Search  -->
                <div>
                  <div class="fw-700 fs-22">Sarah Johnson</div>
                  <div class="d-flex gap-2 mt-2">
                    <div class="fs-14">
                      <span>Department:</span>
                      <span
                        class="fw-600 border-2 ms-2 p-2"
                        style="background-color: #F4FAFF">Engineering</span
                      >
                    </div>
                    <div class="fs-14">
                      <span>Year:</span>
                      <span
                        class="fw-600 border-2 ms-2 p-2"
                        style="background-color: #F4FAFF">2026</span
                      >
                    </div>
                    <div class="fs-14 px-2 mx-2 border-2 border-start">
                      <span>Manager:</span>
                      <span
                        class="fw-600 border-2 ms-2 p-2"
                        style="background-color: #F4FAFF">Joy Awodele</span
                      >
                    </div>
                  </div>
                </div>

                <!-- Others -->
                <div class="responsive gap-4 align-items-center">
                  <button
                    class="btn bg-primary-blue d-flex align-items-center text-white fs-14 py-2"
                    type="button"
                    data-bs-toggle="modal"
                    data-bs-target="#myModal"
                    data-title="Add Checkpoints"
                    ><span class="fw-700 fs-14">+</span><span
                      class="ms-2 text-nowrap">Add Checkpoints</span
                    >
                  </button>
                  <!---- End of Others ---->
                </div>
              </div>

              <div class="d-flex gap-5">
                <div
                  class="d-flex flex-column gap-3 py-4 px-4 border rounded-5 w-50"
                >
                  <div class="fs-14">Period</div>
                  <div class="d-flex gap-3 align-items-center">
                    <h1 class="fs-16 fw-700">
                      2nd, Jan 2026 --- 23rd, Feb 2026
                    </h1>
                  </div>
                </div>
                <div
                  class="d-flex flex-column gap-3 py-4 px-4 border rounded-5 w-50"
                >
                  <div class="fs-14">Outcome</div>
                  <div class="d-flex gap-3 align-items-center">
                    <span
                      class="fw-700 border border-1 rounded-3 p-2 fs-12"
                      style="background-color: #E9FFE2; color: #186D00; height: fit-content"
                      role="button">In Progress</span
                    >
                  </div>
                </div>
              </div>
              <div class="d-flex flex-column gap-4 py-4 px-4 border rounded-5">
                <div class="d-flex gap-3">
                  <div>
                    <div class="d-flex gap-3 align-items-center">
                      <h1 class="fs-16 fw-700">Reason</h1>
                    </div>
                    <div class="fs-14">
                      Consistently missed sales targets in 2025 annual review.
                      Needs Improvement outcome.
                    </div>
                  </div>
                </div>
              </div>
              <div class="d-flex flex-column gap-4 py-4 px-4 border rounded-5">
                <div class="d-flex gap-3">
                  <div>
                    <div class="d-flex gap-3 align-items-center">
                      <h1 class="fs-16 fw-700">Required Actions</h1>
                    </div>
                    <div class="fs-14">
                      Complete advanced sales training program, Shadow
                      top-performing rep for 2 weeks, Submit weekly pipeline
                      reports, Achieve minimum 80% of monthly target
                    </div>
                  </div>
                </div>
              </div>
              <div class="d-flex flex-column gap-4 py-4 px-4 border rounded-5">
                <div class="d-flex gap-3">
                  <div>
                    <div class="d-flex gap-3 align-items-center">
                      <h1 class="fs-16 fw-700">Areas for Improvement</h1>
                    </div>
                    <div class="fs-14">Support/Training Plan</div>
                  </div>
                </div>
              </div>
              <div
                class="d-flex flex-column gap-3 py-3 px-4 border border-1 rounded-5"
              >
                <div class="d-flex justify-content-between">
                  <div>
                    <h3 class="fs-16 fw-700">Checkpoints</h3>
                    <p class="fs-14 text-grey">
                      <span class="border-end pe-2">7 April, 2025</span>
                      <span class="ps-2">8:00 PM</span>
                    </p>
                  </div>
                </div>
                <div
                  class="rounded-4 p-3 w-75 fs-14"
                  style="background-color: #F9F9F9;"
                >
                  <p>
                    Robert completed sales training. Pipeline has improved
                    slightly. Closed 2 new deals worth $45K. Still below target
                    but showing effort.
                  </p>
                  <span
                    class="fw-700 border border-1 rounded-3 p-2 fs-14"
                    style="background-color: #fff; height: fit-content; border:#2271B6"
                    role="button">Partially Improved</span
                  >
                </div>
                <div class="d-flex justify-content-between pt-3 border-top">
                  <div>
                    <p class="fs-14 text-grey">
                      <span class="border-end pe-2">7 April, 2025</span>
                      <span class="ps-2">8:00 PM</span>
                    </p>
                  </div>
                </div>
                <div
                  class="rounded-4 p-3 w-75 fs-14"
                  style="background-color: #F9F9F9;"
                >
                  <p>
                    Robert completed sales training. Pipeline has improved
                    slightly. Closed 2 new deals worth $45K. Still below target
                    but showing effort.
                  </p>
                  <span
                    class="fw-700 border border-1 rounded-3 p-2 fs-14"
                    style="background-color: #fff; height: fit-content; border:#2271B6"
                    role="button">Partially Improved</span
                  >
                </div>
              </div>
            </div>
          </div>

          <ModalAddNew
            modalId="myModal"
            title={"Add Checkpoints"}
            inputPlace="Add Checkpoints"
          />
        </div>
      </div>
      <!-- Main content ends here -->
    </section>

    <script is:inline type="text/javascript">
      // Handle opening the modal
      document
        .querySelectorAll('[data-bs-target="#addCard"]')
        .forEach((button) => {
          button.addEventListener("click", function () {
            const modalTitle =
              this.getAttribute("data-title") || "Edit Bank Transfer Info";
            const empType = this.getAttribute("data-emp-type") || "";

            // Update modal title
            const modalTitleElement = document.getElementById("modalTitle");
            if (modalTitleElement) {
              modalTitleElement.textContent = modalTitle;
            }

            // Update input field
            const employeeStatusInput =
              document.getElementById("employee_title");
            if (employeeStatusInput) {
              employeeStatusInput.value = empType;
            }
          });
        });
    </script>
  </main>
</Layout>
