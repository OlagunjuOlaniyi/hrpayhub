---
import Layout from "../layouts/Layout.astro";
import ModalSubscriptionButton from "../components/ui/ModalSubscriptionButton.astro";
import CancelSubscription from "../components/ui/CancelSubscription.astro";
import ModalSubscriptionMid from "../components/ui/ModalSubscriptionMid.astro";
import ModalAddNew from "../components/ui/ModalAddNew.astro";

import { Naira, Pounds } from "../components/Symbols";
---

<Layout title="HRPayHub :: Company Goals">
  <!-- Main content starts here -->
  <main>
    <!-- First section of Back button and Breadcrumb -->
    <section class="p-4">
      <div class="screenFrame">
        <!-- Back Navigation button and BreadCrumbs -->
        <div class="d-flex gap-5">
          <a
            href="/performance-management"
            title="Back to Dashboard"
            class="d-flex gap-2 align-items-center text-decoration-none text-primary-dark"
          >
            <img src="images/png/icons/angle-left.svg" alt="angle-left-back" />
            <span class="fs-16 fw-bold font-avenir-bold">Back</span>
          </a>

          <!-- Actual Breadcrumb here -->
          <div class="d-flex align-items-center gap-2">
            <a
              href="index.html"
              class="fs-14 text-decoration-none text-primary-dark">Dashboard</a
            >
            <img
              src="images/png/icons/angle-right.svg"
              alt="angle-right-back"
            />
            <a
              href="/performance-management"
              class="fs-14 text-decoration-none text-primary-dark"
              >Performance Management</a
            >
            <img
              src="images/png/icons/angle-right.svg"
              alt="angle-right-back"
            />
            <span class="fs-16 fw-bold text-primary-blue">Company Goals</span>
          </div>
          <!-- Actual Breadcrumb here -->
        </div>
        <!-- Back Navigation button and BreadCrumbs -->
      </div>
    </section>
    <!-- First section of Back button and Breadcrumb -->

    <!-- First section of Back button and Breadcrumb -->
    <section class="px-4">
      <div class="screenFrame">
        <div class="rounded-4 shadow p-4 vstack gap-5 px-5">
          {/* Page Content Box */}
          <div class="p-lg-5">
            <div class="vstack px-5" style="gap: 2.3rem">
              <div class="d-flex justify-content-between gap-3">
                <!---- Search  -->
                <div>
                  <div class="fw-700 fs-22">Company Goals</div>
                  <div class="fs-14">
                    Organisation-wide performance goals for each review year
                  </div>
                </div>

                <!-- Others -->
                <div class="responsive gap-4 align-items-center">
                  <!-- Calendar Selector -->
                  <input
                    type="month"
                    class="form-control fs-14 py-2"
                    style="max-width: 150px;"
                    value="2026-04"
                  />
                  <div class="d-flex justify-content-end">
                    <button
                      class="btn bg-primary-blue d-flex align-items-center text-white fs-14 py-2"
                      type="button"
                      data-bs-toggle="modal"
                      data-bs-target="#myModal"
                      data-title="Create Company Goal"
                      ><span class="fw-700 fs-14">+</span><span
                        class="ms-2 text-nowrap">Add Goal</span
                      >
                    </button>
                  </div>

                  <!---- End of Others ---->
                </div>
              </div>
              <div class="d-flex flex-column gap-4 py-4 px-4 border rounded-5">
                <div class="d-flex justify-content-between">
                  <div>
                    <h1 class="fs-16 fw-700">Increase Annual Revenue by 25%</h1>
                    <div class="fs-14">
                      Drive revenue growth through new product launches, market
                      expansion, and improved sales processes.
                    </div>
                  </div>
                  <span
                    class="fw-700 border border-1 rounded-3 p-2 ms-2 fs-12"
                    style="background-color: #E9FFE2; color: #186D00; height: fit-content"
                    role="button">Active</span
                  >
                </div>

                <div class="d-flex gap-2">
                  <div class="fs-14">
                    <span>Year:</span>
                    <span
                      class="fw-600 border-2 ms-2 p-2"
                      style="background-color: #F4FAFF">2026</span
                    >
                  </div>
                  <div class="fs-14 px-2 mx-2 border-2 border-start border-end">
                    <span>Created By:</span>
                    <span
                      class="fw-600 border-2 ms-2 p-2"
                      style="background-color: #F4FAFF">Joy Awodele</span
                    >
                  </div>
                  <div class="fs-14">
                    <span>Weight:</span>
                    <span
                      class="fw-600 border-2 p-2"
                      style="background-color: #F4FAFF">30%</span
                    >
                  </div>
                  <div class="fs-14 px-2 mx-2 border-2 border-start">
                    <span>Date:</span>
                    <span
                      class="fw-600 border-2 ms-2 p-2"
                      style="background-color: #F4FAFF"
                      >1st, Jan 2026 - 31st, Dec 2026</span
                    >
                  </div>
                </div>
              </div>
