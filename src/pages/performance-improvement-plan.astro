                    style="background-color: #fff; color: #2271B6; height: fit-content; border:#2271B6; text-decoration: none;"
                    href="/pip-details">View Details</a
                  >
                </div>

                <div class="d-flex gap-2">
                  <div class="fs-14">
                    <span>Department:</span>
                    <span
