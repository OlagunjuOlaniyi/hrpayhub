                    >
                  </div>
                  <div class="fs-14 px-2 mx-2 border-2 border-start border-end">
                    <span>Manager:</span>
                    <span
                      class="fw-600 border-2 ms-2 p-2"
                      style="background-color: #F4FAFF">Joy Awodele</span
                    >
                  </div>
                  <div class="fs-14">
                    <span>Outcome:</span>
                    <span
                      class="fw-600 border-2 p-2"
                      style="background-color: #F4FAFF">In Progress</span
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>

          <ModalAddNew
            modalId="myModal"
            title={"Create PIP"}
            inputPlace="Create PIP"
          />
        </div>
      </div>
      <!-- Main content ends here -->
    </section>

    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        // Wait a bit to ensure scripts are loaded (important in Astro)
        setTimeout(() => {
          if (window.$ && $.fn.select2) {
            $(".js-example-placeholder-single").select2({
              placeholder: "All Departments",
              allowClear: true,
              width: "fit-content", // important for Bootstrap layout
            });
          } else {
            console.error("Select2 or jQuery not loaded");
          }
        }, 100);
      });
    </script>
  </main>
</Layout>
